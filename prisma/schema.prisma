generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.png"
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id          Int       @id @default(autoincrement()) // ✅ 단일 PK
  user_id     Int
  title       String    @db.VarChar(50)
  content     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User     @relation(fields: [user_id], references: [user_id]) // 👈 핵심

  @@index([user_id]) // 유저별 조회 빠르게
  @@map("notes") // ← 실제 테이블명
}

model User {
  user_id     Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  auth_status String    @default("P") @db.Char(1) // V: 인증완료, P: 인증대기, F: 거졀, E: 완료, R: 취소
  is_admin    Boolean   @default(false) // 관리자인지 여부 (관리자는 유저 관리)
  createdAt   DateTime  @default(now())

  notes       Note[]    // 역참조
  inventories Inventory[] // ← Inventory와의 관계 추가

  @@map("users")
}

// 카테고리 enum
enum Category {
  VEG   // 야채
  SPICE // 조미료
  SAUCE // 양념장
  MEAT  // 고기
  ETC   // 기타
}

// 보관방법 enum
enum Storage {
  R  // 냉장
  F  // 냉동
}

model Inventory {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(50)
  entryDate DateTime  // 입고일자
  price     Int?
  category  Category
  storage   Storage
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [user_id], references: [user_id])
  user_id   Int?

  @@map("inventories") // 테이블명을 정식 복수형으로
}