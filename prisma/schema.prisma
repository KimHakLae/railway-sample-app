generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  note_id   Int      @default(autoincrement())
  user_id   Int
  title     String
  content   String?
  createdAt DateTime @default(now())

  @@id([note_id, user_id])
  @@map("notes")
}

model User {
  user_id   Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("users")
}