generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.png"
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id          Int       @id @default(autoincrement()) // ✅ 단일 PK
  user_id     Int
  title       String    @db.VarChar(50)
  content     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User     @relation(fields: [user_id], references: [user_id]) // 👈 핵심

  @@index([user_id]) // 유저별 조회 빠르게
  @@map("notes") // ← 실제 테이블명
}

model User {
  user_id     Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  auth_status String    @default("P") @db.Char(1) // V: 인증완료, P: 인증대기, F: 거졀, E: 완료, R: 취소
  is_admin    Boolean   @default(false) // 관리자인지 여부 (관리자는 유저 관리)
  createdAt   DateTime  @default(now())

  notes       Note[]    // 역참조
  inventories Inventory[] // ← Inventory와의 관계 추가

  @@map("users")
}

// 카테고리 enum
enum Category {
  VEG         // 야채
  FRUIT       // 과일
  SPICE       // 조미료
  SAUCE       // 양념장
  MEAT        // 고기
  SNACK       // 간식
  FOOD        // 음식
  FROZEN_FOOD // 냉동식품
  ETC         // 기타
}

// 보관방법 enum
enum Storage {
  R  // 냉장
  F  // 냉동
  RT // 상온
}

model Item {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(50)
  category  Category   @default(ETC)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  inventories Inventory[] // 유저별 재고와 연결

  @@map("items")
}

model Inventory {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [user_id], references: [user_id])
  user_id     Int

  item        Item      @relation(fields: [item_id], references: [id])
  item_id     Int

  storage     Storage   @default(R)
  entryDate   DateTime
  expiryDate  DateTime?
  price       Int?
  quantity    Int       @default(0)
  is_urgent   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("inventories")
  @@index([user_id])
  @@index([item_id])
}