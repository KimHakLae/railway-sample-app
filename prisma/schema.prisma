generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.png"
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id        Int      @id @default(autoincrement())
  user_id   Int
  title     String   @db.VarChar(50)
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@map("notes")
}

model User {
  user_id     Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  auth_status String   @default("P") @db.Char(1)
  is_admin    Boolean  @default(false)
  createdAt   DateTime @default(now())
  notes       Note[]
  recipes     Recipe[]
  stocks      Stock[]

  @@map("users")
}

model Ingredient {
  id                Int                @id @default(autoincrement())
  name              String             @db.VarChar(50)
  version           String?            @db.VarChar(20)
  category          Category           @default(ETC)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  recipeIngredients RecipeIngredient[]
  stocks            Stock[]

  @@map("ingredients")
}

model Stock {
  id            Int        @id @default(autoincrement())
  user_id       Int
  ingredient_id Int
  storage       Storage    @default(R)
  entryDate     DateTime
  expiryDate    DateTime?
  price         Int?
  quantity      Int        @default(0)
  is_urgent     Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  ingredient    Ingredient @relation(fields: [ingredient_id], references: [id])
  user          User       @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@index([ingredient_id])
  @@map("stocks")
}

model Recipe {
  id           Int                @id @default(autoincrement())
  user_id      Int
  title        String             @db.VarChar(100)
  description  String?
  instructions String?
  difficulty   Int                @default(1)
  cookTime     Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  ingredients  RecipeIngredient[]
  user         User               @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@map("recipes")
}

model RecipeIngredient {
  id            Int        @id @default(autoincrement())
  recipe_id     Int
  ingredient_id Int
  amount        String?    @db.VarChar(50)
  ingredient    Ingredient @relation(fields: [ingredient_id], references: [id])
  recipe        Recipe     @relation(fields: [recipe_id], references: [id])

  @@index([recipe_id])
  @@index([ingredient_id])
  @@map("recipe_ingredients")
}

enum Category {
  VEG
  FRUIT
  SPICE
  SAUCE
  MEAT
  DAIRY
  GRAIN
  SNACK
  FOOD
  FROZEN_FOOD
  ETC
}

enum Storage {
  R
  F
  RT
}
